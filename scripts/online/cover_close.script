# This script close the telescope cover
# Require a CoverCalibrator driver

from ccdciel import ccdciel;
import sys

# Close cover
resp = ccdciel('COVER_CLOSE')['result']['status']
if resp!='OK!':
   sys.exit(1)

# Show status
txt = ccdciel('coverstatus')['result']
ccdciel('logMsg','Cover is now '+txt)

